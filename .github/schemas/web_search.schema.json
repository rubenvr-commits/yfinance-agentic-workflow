{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "web-search",
  "type": "object",
  "properties": {
    "query": {"type": "string"},
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {"type": "string"},
          "url": {"type": "string", "format": "uri"},
          "snippet": {"type": "string"},
          "source": {"type": "string"}
        },
        "required": ["title","url"]
      }
    }
  },
  "required": ["query","results"]
}
