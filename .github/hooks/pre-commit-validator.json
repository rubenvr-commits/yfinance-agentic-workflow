{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "python .github/scripts/validate_pre_commit.py",
        "cwd": ".",
        "timeout": 120,
        "allowed_commands": [
          "python .github/scripts/validate_pre_commit.py"
        ],
        "transcript_dir": ".github/hooks/logs/pre_commit_validator",
        "description": "Validate code quality before git commit - runs Q&A Tester on changed files"
      }
    ]
  }
}
